{
  "theme": "dark",
  "permissions": {
    "allow": [
      "Bash(git * add *)",
      "Bash(git * commit *)",
      "Bash(git * diff *)",
      "Bash(git * log *)",
      "Bash(git * status *)",
      "Bash(git * show *)",
      "Bash(git * cherry-pick *)",
      "Bash(git * fetch *)",
      "Bash(git * tag *)",
      "Bash(docker ps *)",
      "Bash(docker build *)",
      "Bash(docker logs *)",
      "Bash(gh * --help)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr status *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh repo list *)",
      "Bash(gh repo view *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(gh search *)",
      "Bash(gh status *)",
      "Bash(gh label list *)",
      "Bash(gh ruleset list *)",
      "Bash(gh ruleset view *)"
    ],
    "deny": []
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "tmux"
}